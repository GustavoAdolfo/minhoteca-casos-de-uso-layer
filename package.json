{
  "name": "@gustavoadolfo/minhoteca-casos-de-uso-layer",
  "description": "Camada de negócios e casos de uso da Minhoteca",
  "version": "0.3.0",
  "main": "layer/nodejs/dist/index.js",
  "types": "layer/nodejs/dist/index.d.ts",
  "files": [
    "layer/nodejs/dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GustavoAdolfo/minhoteca-casos-de-uso-layer.git"
  },
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/GustavoAdolfo/minhoteca-casos-de-uso-layer/issues"
  },
  "homepage": "https://github.com/GustavoAdolfo/minhoteca-casos-de-uso-layer#readme",
  "scripts": {
    "build": "cd layer/nodejs && tsc && tsc-alias",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:all": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --watch",
    "lint": "eslint layer/nodejs/src tests --ext .ts",
    "lint:fix": "eslint layer/nodejs/src tests --ext .ts --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{js,ts,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,md,json,yml,yaml}\"",
    "clean": "rm -rf layer/nodejs/dist coverage",
    "prepare": "husky"
  },
  "keywords": [
    "minhoteca",
    "biblioteca",
    "comunidade"
  ],
  "author": "Gustavo Adolfo",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "lint-staged": {
    "*.{js,ts,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "{layer/nodejs/src,tests}/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ]
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1053.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@aws-sdk/node-http-handler": "^3.374.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@gustavoadolfo/minhoteca-adapter-layer": "^0.1.6",
    "@gustavoadolfo/minhoteca-core-layer": "^1.0.15",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.59.3",
    "aws-lambda": "^1.0.6",
    "commitlint": "^21.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.5",
    "mongodb": "^7.2.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
